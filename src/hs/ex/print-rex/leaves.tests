-- LEAVES: atomic tokens

=== word | 80
foo

=== number | 80
123

=== quip | 80
'quoted

=== trad string | 80
"hello"

=== multiline trad | 80
"multiline
 string"

=== multiline slug | 80
' line one
' line two

=== span simple | 80
'''hello'''

=== span with quotes | 80
'''say "hello" and 'goodbye'''

=== span multiline | 80
'''first line
   second line'''

=== span in poem | 80
+ x '''content'''

=== span in infix | 80
(a + '''b''')

=== span multiline in poem | 80
+ x '''line one
       line two'''

=== span multiline in nest | 80
(a + '''line one
        line two''')

=== span tight | 80
x.'''y'''

=== page multiline | 80
'''
line one
line two
'''

=== page in poem | 80
+ x '''
    content here
    and more
    '''

=== nested trad | 80
| foo | bar - "line one
               line two"

=== nested slug | 80
| foo | bar - ' line one
              ' line two

=== nested page | 80
| foo | bar - '''
              Page String
              More Content
              '''

=== nested span | 80
| foo | bar - '''span content'''

=== deeply nested multiline page | 80
| a | b | c | d - '''
                  line one
                  line two
                  '''
